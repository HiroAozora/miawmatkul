# -------------------------------------------------------------
# MIAWMATKUL CONFIGURATION FILE
# -------------------------------------------------------------
# File ini adalah contoh konfigurasi environment variables.
# 1. Duplikat file ini dan ubah namanya menjadi `.env`
# 2. Isi value di bawah sesuai dengan API Key yang kamu miliki
# -------------------------------------------------------------

# API Key untuk Google Gemini (Digunakan untuk fitur Magic Paste / Ekstraksi jadwal dari Teks)
# Dapatkan API Key gratis di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
